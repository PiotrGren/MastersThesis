# =========================
# Django / API
# =========================
DJANGO_SETTINGS_MODULE=stockProject.settings
DEBUG=1
SECRET_KEY='django-insecure-zrz$uuw!l+*=^b&!4071)bz0%9ma9rqa@di%(z5aqhl$ifsw)0'
ALLOWED_HOSTS=localhost,127.0.0.1,api

# Katalog na logi (montowany voluemem ./logs:/logs)
LOG_DIR=/logs
ENV=dev
SERVICE_NAME=api
SERVICE_VERSION=1.0.0
CONTAINER_ID=api

# (opcjonalnie) CORS – jeśli potrzebujesz frontu z przeglądarki
# CORS_ALLOWED_ORIGINS=http://localhost:3000

# =========================
# Baza danych (PostgreSQL)
# =========================
DB_NAME=stock
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=db
DB_PORT=5432

# Django DATABASE_URL (opcjonalnie, jeśli używasz dj-database-url)
# DATABASE_URL=postgres://postgres:postgres@db:5432/stock

# =========================
# Celery / Redis
# =========================
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
# Domyślna strefa Celery
CELERY_TIMEZONE=UTC

# Harmonogram Celery Beat (sekundy)
SCHED_MATCH_S=5
SCHED_RATES_S=10
SCHED_BALANCES_S=7.5
SCHED_EXPIRE_S=60

# Tagi eksperymentu (logi JSONL; opcjonalne)
EXPERIMENT_ID=exp-local
PHASE=dev
SCENARIO_ID=default

# =========================
# Monitor kontenerów
# =========================
# 0 = nie zapisuje do DB (zostaje JSONL jako źródło prawdy)
MONITOR_DB_ENABLED=0

# =========================
# Token Auth (DRF)
# =========================
# Jeśli używasz DRF TokenAuth — nic nie trzeba; zostaw jako info.
# Możesz też dodać ustawienia e-mail, SENTRY, itp. gdy będą potrzebne.
